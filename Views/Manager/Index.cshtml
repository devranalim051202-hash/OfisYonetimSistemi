@model IEnumerable<OfisYonetimSistemi.Models.User>

@{
    ViewData["Title"] = "Mudur Paneli";
}

<section class="dashboard-page">
    <div class="dashboard-header">
        <div>
            <p class="eyebrow"><i class="bi bi-speedometer2 me-2"></i>Yönetim Paneli</p>
            <h1>Müdür Gösterge Panosu</h1>
            <p>Personel hesaplarını yönetin ve sistemdeki temel metrikleri buradan anlık takip edin.</p>
        </div>
        <a class="btn btn-primary shadow-sm" asp-controller="Manager" asp-action="CreatePersonnel"><i class="bi bi-person-plus-fill me-2"></i>Personel Ekle</a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success shadow-sm"><i class="bi bi-check-circle-fill me-2"></i>@TempData["SuccessMessage"]</div>
    }

    <div class="dashboard-stats">
        <div class="position-relative">
            <i class="bi bi-people position-absolute text-primary opacity-25" style="font-size: 4rem; top: 1rem; right: 1.5rem;"></i>
            <span>@ViewBag.PersonnelCount</span>
            <p class="d-flex align-items-center"><i class="bi bi-person-badge me-2"></i>Personel Sayısı</p>
        </div>
        <div class="position-relative">
            <i class="bi bi-briefcase position-absolute text-success opacity-25" style="font-size: 4rem; top: 1rem; right: 1.5rem;"></i>
            <span>@ViewBag.ProjectCount</span>
            <p class="d-flex align-items-center"><i class="bi bi-kanban me-2"></i>Aktif Projeler</p>
        </div>
        <div class="position-relative">
            <i class="bi bi-file-earmark-text position-absolute text-warning opacity-25" style="font-size: 4rem; top: 1rem; right: 1.5rem;"></i>
            <span>@ViewBag.InvoiceCount</span>
            <p class="d-flex align-items-center"><i class="bi bi-folder2-open me-2"></i>Kayıtlı Evraklar</p>
        </div>
        <div class="position-relative">
            <i class="bi bi-wallet2 position-absolute text-danger opacity-25" style="font-size: 4rem; top: 1rem; right: 1.5rem;"></i>
            <span>@ViewBag.ExpenseCount</span>
            <p class="d-flex align-items-center"><i class="bi bi-cash-coin me-2"></i>Toplam Gider</p>
        </div>
    </div>

    <div class="premium-list-panel mt-4">
        <div class="premium-list-header border-bottom pb-3 mb-4">
            <div>
                <span class="premium-panel-label"><i class="bi bi-diagram-3 me-2"></i>Ekip Yönetimi</span>
                <h2 class="mt-2">Kayıtlı Personeller</h2>
            </div>
            <span class="premium-count bg-light"><i class="bi bi-people-fill me-2"></i>@Model.Count() Personel</span>
        </div>

        @if (!Model.Any())
        {
            <div class="premium-empty-state">
                <span>+</span>
                <h3>Henuz personel eklenmedi</h3>
                <p>Yeni personel hesabi acarak ekip icindeki is akislarini rol bazli yonetin.</p>
                <a class="btn btn-primary" asp-controller="Manager" asp-action="CreatePersonnel">Personel Ekle</a>
            </div>
        }
        else
        {
            <div class="personnel-card-grid">
                @foreach (var user in Model)
                {
                    <article class="personnel-card">
                        <div class="personnel-avatar">@user.FullName.Substring(0, 1).ToUpper()</div>
                        <div class="personnel-info">
                            <h3>@user.FullName</h3>
                            <p>@user.Email</p>
                        </div>
                        <div class="personnel-details">
                            <span>@(string.IsNullOrWhiteSpace(user.PhoneNumber) ? "Telefon yok" : user.PhoneNumber)</span>
                            <span>@user.CompanyName (@user.CompanySize kisi)</span>
                        </div>
                        <span class="role-chip">@user.Role?.Name</span>
                    </article>
                }
            </div>
        }
    </div>
</section>
