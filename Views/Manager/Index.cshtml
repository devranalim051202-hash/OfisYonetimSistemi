@model IEnumerable<OfisYonetimSistemi.Models.User>

@{
    ViewData["Title"] = "Mudur Paneli";
    var recentLogs = ViewBag.RecentActivityLogs as IEnumerable<OfisYonetimSistemi.Models.ActivityLog> ?? Enumerable.Empty<OfisYonetimSistemi.Models.ActivityLog>();
}

<section class="dashboard-page">
    <div class="dashboard-header">
        <div>
            <p class="eyebrow">Yonetim Paneli</p>
            <h1>Mudur ana sayfasi</h1>
            <p>Personel hesaplarini buradan olusturabilir ve sistemdeki temel kayitlari takip edebilirsiniz.</p>
        </div>
        <div class="hero-actions">
            <a class="btn btn-outline-secondary" asp-controller="ActivityLogs" asp-action="Index">Tum Islemler</a>
            <a class="btn btn-primary" asp-controller="Manager" asp-action="CreatePersonnel">Personel Ekle</a>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">@TempData["SuccessMessage"]</div>
    }

    <div class="dashboard-stats">
        <div>
            <span>@ViewBag.PersonnelCount</span>
            <p>Personel</p>
        </div>
        <div>
            <span>@ViewBag.ProjectCount</span>
            <p>Proje</p>
        </div>
        <div>
            <span>@ViewBag.InvoiceCount</span>
            <p>Evrak</p>
        </div>
        <div>
            <span>@ViewBag.ExpenseCount</span>
            <p>Gider</p>
        </div>
    </div>

    <div class="premium-list-panel">
        <div class="premium-list-header">
            <div>
                <span class="premium-panel-label">Denetim</span>
                <h2>Son islemler</h2>
            </div>
            <a class="btn btn-outline-primary btn-sm" asp-controller="ActivityLogs" asp-action="Index">Tumunu Gor</a>
        </div>

        @if (!recentLogs.Any())
        {
            <div class="premium-empty-state">
                <span>i</span>
                <h3>Henuz islem logu yok</h3>
                <p>Proje, gider, evrak, satis veya giris islemleri yapildikca burada gorunecek.</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table align-middle">
                    <thead>
                        <tr>
                            <th>Tarih</th>
                            <th>Kullanici</th>
                            <th>Modul</th>
                            <th>Islem</th>
                            <th>Durum</th>
                            <th>Aciklama</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var log in recentLogs)
                        {
                            <tr>
                                <td>@log.CreatedAt.ToString("dd.MM HH:mm")</td>
                                <td>@log.UserFullName</td>
                                <td>@log.ModuleName</td>
                                <td>@log.Action</td>
                                <td>
                                    <span class="status-pill @(log.IsSuccessful ? "" : "status-danger")">
                                        @(log.IsSuccessful ? "Basarili" : "Basarisiz")
                                    </span>
                                </td>
                                <td>@log.Description</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>

    <div class="premium-list-panel">
        <div class="premium-list-header">
            <div>
                <span class="premium-panel-label">Ekip Yonetimi</span>
                <h2>Kayitli personeller</h2>
            </div>
            <span class="premium-count">@Model.Count() personel</span>
        </div>

        @if (!Model.Any())
        {
            <div class="premium-empty-state">
                <span>+</span>
                <h3>Henuz personel eklenmedi</h3>
                <p>Yeni personel hesabi acarak ekip icindeki is akislarini rol bazli yonetin.</p>
                <a class="btn btn-primary" asp-controller="Manager" asp-action="CreatePersonnel">Personel Ekle</a>
            </div>
        }
        else
        {
            <div class="personnel-card-grid">
                @foreach (var user in Model)
                {
                    <article class="personnel-card">
                        <div class="personnel-avatar">@user.FullName.Substring(0, 1).ToUpper()</div>
                        <div class="personnel-info">
                            <h3>@user.FullName</h3>
                            <p>@user.Email</p>
                        </div>
                        <div class="personnel-details">
                            <span>@(string.IsNullOrWhiteSpace(user.PhoneNumber) ? "Telefon yok" : user.PhoneNumber)</span>
                            <span>@user.CompanyName (@user.CompanySize kisi)</span>
                        </div>
                        <span class="role-chip">@user.Role?.Name</span>
                    </article>
                }
            </div>
        }
    </div>
</section>
