@model IEnumerable<OfisYonetimSistemi.Models.User>

@{
    ViewData["Title"] = "Personeller";
    var lastDate = ViewBag.LastPersonnelDate as DateTime?;
}

<section class="personnel-premium-page">
    <div class="personnel-premium-hero">
        <div>
            <p class="eyebrow">Ekip Yonetimi</p>
            <h1>Personeller</h1>
            <p>Ofis ekibindeki kullanici hesaplarini, rollerini ve panel erisim durumlarini tek ekrandan yonetin.</p>
        </div>
        <div class="personnel-premium-actions">
            <a class="btn btn-outline-secondary" asp-controller="Manager" asp-action="Index">Dashboard</a>
            <a class="btn btn-primary" asp-controller="Manager" asp-action="CreatePersonnel">Personel Ekle</a>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">@TempData["SuccessMessage"]</div>
    }

    <div class="personnel-metrics">
        <article>
            <span>Toplam Personel</span>
            <strong>@ViewBag.TotalPersonnel</strong>
        </article>
        <article>
            <span>Aktif Hesap</span>
            <strong>@ViewBag.ActivePersonnel</strong>
        </article>
        <article>
            <span>Rol Cesidi</span>
            <strong>@ViewBag.RoleCount</strong>
        </article>
        <article>
            <span>Son Eklenen</span>
            <strong>@(lastDate.HasValue ? lastDate.Value.ToString("dd.MM") : "-")</strong>
        </article>
    </div>

    <div class="personnel-premium-panel">
        <div class="personnel-panel-header">
            <div>
                <span class="premium-panel-label">Kayıtlı Ekip</span>
                <h2>Personel Listesi</h2>
            </div>
            <span class="premium-count">@Model.Count() kayit</span>
        </div>

        @if (!Model.Any())
        {
            <div class="premium-empty-state personnel-empty">
                <span>+</span>
                <h3>Henuz personel eklenmedi</h3>
                <p>Ilk personel hesabini olusturarak ekip icindeki gorev ve yetki dagilimini baslatin.</p>
                <a class="btn btn-primary" asp-controller="Manager" asp-action="CreatePersonnel">Personel Ekle</a>
            </div>
        }
        else
        {
            <div class="personnel-premium-grid">
                @foreach (var user in Model)
                {
                    var initial = string.IsNullOrWhiteSpace(user.FullName) ? "P" : user.FullName.Substring(0, 1).ToUpper();
                    <article class="personnel-premium-card">
                        <div class="personnel-card-top">
                            <div class="personnel-avatar premium-avatar">@initial</div>
                            <span class="role-chip">@user.Role?.Name</span>
                        </div>

                        <div class="personnel-info">
                            <h3>@user.FullName</h3>
                            <p>@user.Email</p>
                        </div>

                        <dl class="personnel-profile-list">
                            <div>
                                <dt>Telefon</dt>
                                <dd>@(string.IsNullOrWhiteSpace(user.PhoneNumber) ? "Kayit yok" : user.PhoneNumber)</dd>
                            </div>
                            <div>
                                <dt>Sirket</dt>
                                <dd>@user.CompanyName</dd>
                            </div>
                            <div>
                                <dt>Kayit Tarihi</dt>
                                <dd>@user.CreatedAt.ToString("dd.MM.yyyy")</dd>
                            </div>
                        </dl>

                        <div class="personnel-card-footer">
                            <span class="status-dot"></span>
                            <span>Panel erisimi aktif</span>
                        </div>
                    </article>
                }
            </div>
        }
    </div>
</section>
