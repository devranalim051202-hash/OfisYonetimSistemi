@model OfisYonetimSistemi.Models.Material

<div class="col-md-8">
    <label asp-for="Name" class="form-label">Malzeme adi</label>
    <input asp-for="Name" class="form-control">
    <span asp-validation-for="Name" class="text-danger"></span>
</div>

<div class="col-md-4">
    <label asp-for="Unit" class="form-label">Birim</label>
    <input asp-for="Unit" class="form-control" placeholder="adet, kg, torba">
    <span asp-validation-for="Unit" class="text-danger"></span>
</div>

<div class="col-md-6">
    <label asp-for="Category" class="form-label">Kategori</label>
    <input asp-for="Category" class="form-control" placeholder="Insaat, boya, elektrik">
    <span asp-validation-for="Category" class="text-danger"></span>
</div>

<div class="col-md-6">
    <label asp-for="MinimumStockLevel" class="form-label">Minimum stok seviyesi</label>
    <input asp-for="MinimumStockLevel" type="number" step="0.01" min="0" class="form-control">
    <span asp-validation-for="MinimumStockLevel" class="text-danger"></span>
</div>

<div class="col-md-12">
    <label asp-for="Description" class="form-label">Aciklama</label>
    <textarea asp-for="Description" class="form-control" rows="4"></textarea>
    <span asp-validation-for="Description" class="text-danger"></span>
</div>
