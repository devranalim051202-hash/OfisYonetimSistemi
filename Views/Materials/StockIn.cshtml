@model OfisYonetimSistemi.Models.ViewModels.StockMovementFormViewModel

@{
    ViewData["Title"] = "Stok Girisi";
    var material = (OfisYonetimSistemi.Models.Material)ViewBag.Material;
}

<section class="form-page">
    <div class="form-panel">
        <a class="auth-back-link" asp-controller="Materials" asp-action="Details" asp-route-id="@material.Id">Malzeme detayina don</a>
        <p class="eyebrow">Stok Girisi</p>
        <h1>@material.Name</h1>
        <p class="auth-help">Ofise alinan malzeme miktarini stok girisi olarak kaydedin.</p>

        <form asp-controller="Materials" asp-action="StockIn" method="post" class="row g-3">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="MaterialId" />
            <partial name="_StockMovementForm" model="Model" />

            <div class="col-12">
                <button type="submit" class="btn btn-primary">Stok girisini kaydet</button>
            </div>
        </form>
    </div>
</section>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
