@{
    ViewData["Title"] = "Personel Paneli";
}

<section class="dashboard-page">
    <div class="dashboard-header">
        <div>
            <p class="eyebrow">Personel Paneli</p>
            <h1>Hos geldiniz</h1>
            <p>Bu alan personelin gunluk takip islemleri icin hazirlandi.</p>
        </div>
        <a class="btn btn-outline-secondary" asp-controller="Account" asp-action="Logout">Cikis Yap</a>
    </div>

    <div class="feature-grid">
        <article class="feature-card">
            <span class="feature-number">01</span>
            <h2>Projeler</h2>
            <p>Yetki verildiginde proje kayitlarini goruntuleyebilirsiniz.</p>
        </article>
        <article class="feature-card">
            <span class="feature-number">02</span>
            <h2>Malzemeler</h2>
            <p>Malzeme ve stok hareketleri buradan takip edilecek.</p>
            <a class="btn btn-outline-primary btn-sm mt-3" asp-controller="Materials" asp-action="Index">Malzemelere Git</a>
        </article>
        <article class="feature-card">
            <span class="feature-number">03</span>
            <h2>Evraklar</h2>
            <p>Fatura, fis ve irsaliye kayitlari bu alana baglanacak.</p>
        </article>
        <article class="feature-card">
            <span class="feature-number">04</span>
            <h2>Raporlar</h2>
            <p>Proje bazli ozetler ve gider raporlari sonraki adimda eklenecek.</p>
        </article>
    </div>
</section>
