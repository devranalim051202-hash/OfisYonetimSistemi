@{
    ViewData["Title"] = "Personel Paneli";
    var roleName = Context.Session.GetString("RoleName") ?? "Personel";
    bool canManageProjectExpenses = RolePermissions.CanManageProjectExpenses(roleName);
    bool canManageApartmentInfo = RolePermissions.CanManageApartmentInfo(roleName);
    bool canManageApartmentSales = RolePermissions.CanManageApartmentSales(roleName);

    var roleLead = roleName switch
    {
        "Sekreter" => "Mevcut projelerde operasyonu yurutur; daire bilgisi, gider ve belge akisini takip eder.",
        "Emlak" => "Projeleri, daire durumlarini ve satis tablosunu gorur; musteri tarafindaki takip icin temiz bir okuma alani kullanir.",
        "Muhasebeci" or "Muhasebe" => "Proje giderlerini, belgeleri ve finansal kayitlari duzenli bicimde takip eder.",
        _ => "Size tanimlanan yetkilerle proje sureclerini kontrollu sekilde takip edebilirsiniz."
    };
}

<section class="dashboard-page personnel-brief-page">
    <div class="personnel-brief-hero">
        <div class="personnel-brief-copy">
            <p class="eyebrow">Personel Paneli</p>
            <h1>@roleName Paneli</h1>
            <p>@roleLead</p>
        </div>
        <div class="personnel-brief-actions">
            <a class="btn btn-primary" asp-controller="Projects" asp-action="Index">
                <i class="bi bi-briefcase me-2"></i>Projeleri Ac
            </a>
            <a class="btn btn-outline-secondary" asp-controller="Account" asp-action="Logout">
                <i class="bi bi-box-arrow-right me-2"></i>Cikis Yap
            </a>
        </div>
    </div>

    <div class="personnel-brief-layout">
        <section class="personnel-scope-panel">
            <div class="personnel-panel-heading">
                <span><i class="bi bi-shield-check"></i></span>
                <div>
                    <p class="eyebrow">Yetki Kapsami</p>
                    <h2>Bu rolde neler yapabilirsiniz?</h2>
                </div>
            </div>

            <div class="personnel-scope-list">
                <div class="personnel-scope-item is-available">
                    <i class="bi bi-check2-circle"></i>
                    <div>
                        <strong>Projeleri goruntuleme</strong>
                        <span>Proje listesine girip detay, sure, konum ve daire durumlarini inceleyebilirsiniz.</span>
                    </div>
                </div>

                <div class="personnel-scope-item @(canManageApartmentInfo ? "is-available" : "is-locked")">
                    <i class="bi @(canManageApartmentInfo ? "bi-check2-circle" : "bi-lock")"></i>
                    <div>
                        <strong>Daire bilgilerini duzenleme</strong>
                        <span>@(canManageApartmentInfo ? "Kat, daire no, oda tipi, alan ve fiyat bilgilerini guncelleyebilirsiniz." : "Daire bilgilerini yalnizca goruntuleyebilirsiniz.")</span>
                    </div>
                </div>

                <div class="personnel-scope-item @(canManageProjectExpenses ? "is-available" : "is-locked")">
                    <i class="bi @(canManageProjectExpenses ? "bi-check2-circle" : "bi-lock")"></i>
                    <div>
                        <strong>Gider ve belge islemleri</strong>
                        <span>@(canManageProjectExpenses ? "Proje detayindan gider ve belge kaydi olusturabilirsiniz." : "Gider kayitlari bu rol icin islem alanina dahil degildir.")</span>
                    </div>
                </div>

                <div class="personnel-scope-item @(canManageApartmentSales ? "is-available" : "is-locked")">
                    <i class="bi @(canManageApartmentSales ? "bi-check2-circle" : "bi-lock")"></i>
                    <div>
                        <strong>Daire satis islemi</strong>
                        <span>@(canManageApartmentSales ? "Daire satisi ve sozlesme sureclerini yonetebilirsiniz." : "Satis islemi yalnizca yonetici rollerinde aciktir.")</span>
                    </div>
                </div>
            </div>
        </section>

        <aside class="personnel-flow-panel">
            <p class="eyebrow">Onerilen Akis</p>
            <h2>Isleme nereden baslanir?</h2>
            <ol class="personnel-flow-list">
                <li>
                    <span>01</span>
                    <p>Once proje listesine girin ve ilgili projeyi secin.</p>
                </li>
                <li>
                    <span>02</span>
                    <p>Proje detayinda daire tablosu, belge ve gider alanlarini kontrol edin.</p>
                </li>
                <li>
                    <span>03</span>
                    <p>Yetkiniz olan islemleri proje detayindaki butonlardan tamamlayin.</p>
                </li>
            </ol>
            <div class="personnel-flow-actions">
                <a class="btn btn-primary w-100" asp-controller="Projects" asp-action="Index">
                    <i class="bi bi-arrow-right-circle me-2"></i>Proje Listesine Git
                </a>
            </div>
        </aside>
    </div>
</section>
