@model OfisYonetimSistemi.Models.Expense

@{
    ViewData["Title"] = "Gider Ekle";
}

<section class="dashboard-page">
    <div class="dashboard-header border-bottom pb-3 mb-4">
        <div>
            <p class="eyebrow"><i class="bi bi-receipt me-2"></i>Yeni Gider</p>
            <h1>Gider Ekle</h1>
            <p class="text-muted">Projeye alinan malzeme, miktar ve fiyat bilgisini kaydedin.</p>
        </div>
        <a class="btn btn-outline-secondary shadow-sm" asp-controller="Projects" asp-action="Details" asp-route-id="@Model.ProjectId"><i class="bi bi-arrow-left me-2"></i>Projeye Dön</a>
    </div>

    <div class="table-panel shadow-sm">
        <form asp-action="Create" method="post" enctype="multipart/form-data" class="row g-4">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <partial name="_ExpenseForm" model="Model" />
            <div class="col-12 d-flex gap-3 mt-4 pt-3 border-top">
                <button type="submit" class="btn btn-primary px-4 py-2"><i class="bi bi-check2-circle me-2"></i>Kaydet</button>
                <a class="btn btn-outline-secondary px-4 py-2" asp-controller="Projects" asp-action="Details" asp-route-id="@Model.ProjectId"><i class="bi bi-x-circle me-2"></i>İptal</a>
            </div>
        </form>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (() => {
            const quantity = document.getElementById("Quantity");
            const unitPrice = document.getElementById("UnitPrice");
            const amount = document.getElementById("Amount");

            const calculateAmount = () => {
                const quantityValue = Number(quantity?.value || 0);
                const unitPriceValue = Number(unitPrice?.value || 0);
                const total = quantityValue * unitPriceValue;

                if (amount) {
                    amount.value = total > 0 ? total.toFixed(2) : "";
                }
            };

            quantity?.addEventListener("input", calculateAmount);
            unitPrice?.addEventListener("input", calculateAmount);
            calculateAmount();
        })();
    </script>
}
