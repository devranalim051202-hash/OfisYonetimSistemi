@model OfisYonetimSistemi.Models.Expense

@if (ViewBag.IsProjectScoped == true)
{
    <input type="hidden" asp-for="ProjectId">
}

<input type="hidden" asp-for="ExpenseType" value="Malzeme">
<input type="hidden" asp-for="PaymentStatus" value="Odendi">

<div class="col-md-6">
    <div class="form-floating position-relative">
        <input asp-for="Title" class="form-control ps-4" placeholder="Orn: Cimento">
        <label asp-for="Title" class="ps-4"><i class="bi bi-box me-2 text-muted"></i>Alınan Malzeme / Ürün</label>
    </div>
    <span asp-validation-for="Title" class="text-danger small"></span>
</div>

<div class="col-md-6">
    <div class="form-floating position-relative">
        <input asp-for="SupplierName" class="form-control ps-4" placeholder="Orn: ABC Insaat Malzemeleri">
        <label asp-for="SupplierName" class="ps-4"><i class="bi bi-shop me-2 text-muted"></i>Firma / Tedarikçi</label>
    </div>
    <span asp-validation-for="SupplierName" class="text-danger small"></span>
</div>

<div class="col-md-4">
    <div class="form-floating position-relative">
        <input asp-for="Quantity" type="number" step="0.01" min="0.01" class="form-control ps-4" placeholder="Orn: 50">
        <label asp-for="Quantity" class="ps-4"><i class="bi bi-layers me-2 text-muted"></i>Miktar</label>
    </div>
    <span asp-validation-for="Quantity" class="text-danger small"></span>
</div>

<div class="col-md-4">
    <div class="form-floating position-relative">
        <input asp-for="UnitPrice" type="number" step="0.01" min="0" class="form-control ps-4" placeholder="Orn: 120">
        <label asp-for="UnitPrice" class="ps-4"><i class="bi bi-tag me-2 text-muted"></i>Birim Fiyat</label>
    </div>
    <span asp-validation-for="UnitPrice" class="text-danger small"></span>
</div>

<div class="col-md-4">
    <div class="form-floating position-relative">
        <input asp-for="Amount" type="number" step="0.01" min="0.01" class="form-control ps-4 bg-light" readonly placeholder="Toplam">
        <label asp-for="Amount" class="ps-4"><i class="bi bi-currency-dollar me-2 text-muted"></i>Toplam Fiyat</label>
    </div>
    <span asp-validation-for="Amount" class="text-danger small"></span>
</div>

<div class="col-md-4">
    <div class="form-floating position-relative">
        <input asp-for="ExpenseDate" type="date" class="form-control ps-4">
        <label asp-for="ExpenseDate" class="ps-4"><i class="bi bi-calendar-date me-2 text-muted"></i>Eklenme Tarihi</label>
    </div>
    <span asp-validation-for="ExpenseDate" class="text-danger small"></span>
</div>

<div class="col-md-8">
    <div class="form-floating position-relative">
        <input asp-for="DocumentNumber" class="form-control ps-4" placeholder="Fis no">
        <label asp-for="DocumentNumber" class="ps-4"><i class="bi bi-receipt me-2 text-muted"></i>Fiş / Belge No</label>
    </div>
    <span asp-validation-for="DocumentNumber" class="text-danger small"></span>
</div>

<div class="col-md-12">
    <div class="form-floating position-relative">
        <textarea asp-for="Description" class="form-control ps-4" style="height: 100px" placeholder="Aciklama"></textarea>
        <label asp-for="Description" class="ps-4"><i class="bi bi-card-text me-2 text-muted"></i>Açıklama</label>
    </div>
    <span asp-validation-for="Description" class="text-danger small"></span>
</div>
