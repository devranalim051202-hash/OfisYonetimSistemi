@model OfisYonetimSistemi.Models.Expense

@if (ViewBag.IsProjectScoped == true)
{
    <input type="hidden" asp-for="ProjectId">
}

<input type="hidden" asp-for="ExpenseType" value="Malzeme">
<input type="hidden" asp-for="PaymentStatus" value="Odendi">

<div class="col-md-6">
    <label asp-for="Title" class="form-label">Alinan malzeme / urun</label>
    <input asp-for="Title" class="form-control" placeholder="Orn: Cimento">
    <span asp-validation-for="Title" class="text-danger"></span>
</div>

<div class="col-md-6">
    <label asp-for="SupplierName" class="form-label">Firma / tedarikci</label>
    <input asp-for="SupplierName" class="form-control" placeholder="Orn: ABC Insaat Malzemeleri">
    <span asp-validation-for="SupplierName" class="text-danger"></span>
</div>

<div class="col-md-4">
    <label asp-for="Quantity" class="form-label">Miktar</label>
    <input asp-for="Quantity" type="number" step="0.01" min="0.01" class="form-control" placeholder="Orn: 50">
    <span asp-validation-for="Quantity" class="text-danger"></span>
</div>

<div class="col-md-4">
    <label asp-for="UnitPrice" class="form-label">Birim fiyat</label>
    <input asp-for="UnitPrice" type="number" step="0.01" min="0" class="form-control" placeholder="Orn: 120">
    <span asp-validation-for="UnitPrice" class="text-danger"></span>
</div>

<div class="col-md-4">
    <label asp-for="Amount" class="form-label">Toplam fiyat</label>
    <input asp-for="Amount" type="number" step="0.01" min="0.01" class="form-control" readonly>
    <span asp-validation-for="Amount" class="text-danger"></span>
</div>

<div class="col-md-4">
    <label asp-for="ExpenseDate" class="form-label">Eklenme tarihi</label>
    <input asp-for="ExpenseDate" type="date" class="form-control">
    <span asp-validation-for="ExpenseDate" class="text-danger"></span>
</div>

<div class="col-md-6">
    <label asp-for="DocumentNumber" class="form-label">Fis / belge no</label>
    <input asp-for="DocumentNumber" class="form-control">
    <span asp-validation-for="DocumentNumber" class="text-danger"></span>
</div>

<div class="col-md-12">
    <label asp-for="Description" class="form-label">Aciklama</label>
    <textarea asp-for="Description" class="form-control" rows="4"></textarea>
    <span asp-validation-for="Description" class="text-danger"></span>
</div>
