@model OfisYonetimSistemi.Models.Expense

@if (ViewBag.IsProjectScoped == true)
{
    <input type="hidden" asp-for="ProjectId">
}

<input type="hidden" asp-for="ExpenseType" value="Malzeme">
<input type="hidden" asp-for="PaymentStatus" value="Odendi">
<input type="hidden" asp-for="DocumentFilePath">
<input type="hidden" asp-for="DocumentOriginalFileName">
<input type="hidden" asp-for="DocumentContentType">

<div class="col-md-6">
    <div class="form-floating position-relative">
        <input asp-for="Title" class="form-control ps-4" placeholder="Orn: Cimento">
        <label asp-for="Title" class="ps-4"><i class="bi bi-box me-2 text-muted"></i>Alınan Malzeme / Ürün</label>
    </div>
    <span asp-validation-for="Title" class="text-danger small"></span>
</div>

<div class="col-md-6">
    <div class="form-floating position-relative">
        <input asp-for="SupplierName" class="form-control ps-4" placeholder="Orn: ABC Insaat Malzemeleri">
        <label asp-for="SupplierName" class="ps-4"><i class="bi bi-shop me-2 text-muted"></i>Firma / Tedarikçi</label>
    </div>
    <span asp-validation-for="SupplierName" class="text-danger small"></span>
</div>

<div class="col-md-4">
    <div class="form-floating position-relative">
        <input id="Quantity" name="Quantity" value="@Model.Quantity.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture)" type="number" step="1" min="0" class="form-control ps-4 js-expense-number" placeholder="Orn: 50" data-val="false">
        <label asp-for="Quantity" class="ps-4"><i class="bi bi-layers me-2 text-muted"></i>Miktar</label>
    </div>
    <span asp-validation-for="Quantity" class="text-danger small"></span>
</div>

<div class="col-md-4">
    <div class="form-floating position-relative">
        <input id="UnitPrice" name="UnitPrice" value="@Model.UnitPrice.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture)" type="number" step="1" min="0" class="form-control ps-4 js-expense-number" placeholder="Orn: 120" data-val="false">
        <label asp-for="UnitPrice" class="ps-4"><i class="bi bi-tag me-2 text-muted"></i>Birim Fiyat</label>
    </div>
    <span asp-validation-for="UnitPrice" class="text-danger small"></span>
</div>

<div class="col-md-4">
    <div class="form-floating position-relative">
        <input id="Amount" name="Amount" value="@Model.Amount.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture)" type="number" step="1" min="0" class="form-control ps-4 bg-light js-expense-number" readonly placeholder="Toplam" data-val="false">
        <label asp-for="Amount" class="ps-4"><i class="bi bi-currency-dollar me-2 text-muted"></i>Toplam Fiyat</label>
    </div>
    <span asp-validation-for="Amount" class="text-danger small"></span>
</div>

<div class="col-md-4">
    <div class="form-floating position-relative">
        <input asp-for="ExpenseDate" type="date" class="form-control ps-4">
        <label asp-for="ExpenseDate" class="ps-4"><i class="bi bi-calendar-date me-2 text-muted"></i>Eklenme Tarihi</label>
    </div>
    <span asp-validation-for="ExpenseDate" class="text-danger small"></span>
</div>

<div class="col-md-8">
    <label asp-for="DocumentFile" class="form-label"><i class="bi bi-file-earmark-arrow-up me-2 text-muted"></i>Fiş / Belge Yükle <span class="text-muted fw-normal">(isteğe bağlı)</span></label>
    <input asp-for="DocumentFile" type="file" class="form-control" accept=".pdf,image/*">
    <span asp-validation-for="DocumentFile" class="text-danger small"></span>
    @if (!string.IsNullOrWhiteSpace(Model.DocumentFilePath))
    {
        <small class="text-muted d-block mt-1">
            Kayıtlı belge:
            <a href="@Model.DocumentFilePath" target="_blank"><i class="bi bi-link-45deg"></i>@Model.DocumentOriginalFileName</a>
        </small>
    }
</div>

<div class="col-md-12">
    <div class="form-floating position-relative">
        <textarea asp-for="Description" class="form-control ps-4" style="height: 100px" placeholder="Aciklama" data-val="false"></textarea>
        <label asp-for="Description" class="ps-4"><i class="bi bi-card-text me-2 text-muted"></i>Açıklama (isteğe bağlı)</label>
    </div>
    <span asp-validation-for="Description" class="text-danger small"></span>
</div>
