@model OfisYonetimSistemi.Models.Expense

<div class="col-md-8">
    <label asp-for="Title" class="form-label">Gider basligi</label>
    <input asp-for="Title" class="form-control" placeholder="Orn: Santiye elektrik faturasi">
    <span asp-validation-for="Title" class="text-danger"></span>
</div>

<div class="col-md-4">
    <label asp-for="ExpenseType" class="form-label">Gider turu</label>
    <select asp-for="ExpenseType" asp-items="ViewBag.ExpenseTypes" class="form-select"></select>
    <span asp-validation-for="ExpenseType" class="text-danger"></span>
</div>

@if (ViewBag.IsProjectScoped == true)
{
    <input type="hidden" asp-for="ProjectId">
}
else
{
    <div class="col-md-6">
        <label asp-for="ProjectId" class="form-label">Proje</label>
        <select asp-for="ProjectId" asp-items="ViewBag.Projects" class="form-select">
            <option value="">Proje secilmedi</option>
        </select>
        <span asp-validation-for="ProjectId" class="text-danger"></span>
    </div>
}

<div class="col-md-6">
    <label asp-for="CompanyId" class="form-label">Firma</label>
    <select asp-for="CompanyId" asp-items="ViewBag.Companies" class="form-select">
        <option value="">Firma secilmedi</option>
    </select>
    <span asp-validation-for="CompanyId" class="text-danger"></span>
</div>

<div class="col-md-4">
    <label asp-for="Amount" class="form-label">Tutar</label>
    <input asp-for="Amount" type="number" step="0.01" min="0.01" class="form-control">
    <span asp-validation-for="Amount" class="text-danger"></span>
</div>

<div class="col-md-4">
    <label asp-for="ExpenseDate" class="form-label">Gider tarihi</label>
    <input asp-for="ExpenseDate" type="date" class="form-control">
    <span asp-validation-for="ExpenseDate" class="text-danger"></span>
</div>

<div class="col-md-4">
    <label asp-for="PaymentStatus" class="form-label">Odeme durumu</label>
    <select asp-for="PaymentStatus" asp-items="ViewBag.PaymentStatuses" class="form-select"></select>
    <span asp-validation-for="PaymentStatus" class="text-danger"></span>
</div>

<div class="col-md-6">
    <label asp-for="DocumentNumber" class="form-label">Belge numarasi</label>
    <input asp-for="DocumentNumber" class="form-control">
    <span asp-validation-for="DocumentNumber" class="text-danger"></span>
</div>

<div class="col-md-12">
    <label asp-for="Description" class="form-label">Aciklama</label>
    <textarea asp-for="Description" class="form-control" rows="4"></textarea>
    <span asp-validation-for="Description" class="text-danger"></span>
</div>
