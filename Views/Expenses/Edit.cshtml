@model OfisYonetimSistemi.Models.Expense

@{
    ViewData["Title"] = AppLanguage.T(Context, "ExpenseEdit");
}

<section class="dashboard-page">
    <div class="dashboard-header">
        <div>
            <p class="eyebrow">@AppLanguage.T(Context, "ExpenseEdit")</p>
            <h1>@Model.Title</h1>
            <p>@AppLanguage.T(Context, "ExpenseEditText")</p>
        </div>
        <a class="btn btn-outline-secondary" asp-controller="Projects" asp-action="Details" asp-route-id="@Model.ProjectId">@AppLanguage.T(Context, "BackToProjects")</a>
    </div>

    <div class="table-panel">
        <form asp-action="Edit" asp-route-id="@Model.Id" method="post" enctype="multipart/form-data" class="row g-3" novalidate>
            <input type="hidden" asp-for="Id">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <partial name="_ExpenseForm" model="Model" />
            <div class="col-12 d-flex gap-2">
                <button type="submit" class="btn btn-primary">@AppLanguage.T(Context, "ExpenseUpdate")</button>
                <a class="btn btn-outline-secondary" asp-controller="Projects" asp-action="Details" asp-route-id="@Model.ProjectId">@AppLanguage.T(Context, "Cancel")</a>
            </div>
        </form>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (() => {
            const quantity = document.getElementById("Quantity");
            const unitPrice = document.getElementById("UnitPrice");
            const amount = document.getElementById("Amount");

            const calculateAmount = () => {
                const quantityValue = Number((quantity?.value || "0").replace(",", "."));
                const unitPriceValue = Number((unitPrice?.value || "0").replace(",", "."));
                const total = quantityValue * unitPriceValue;

                if (amount) {
                    amount.value = total > 0 ? total.toFixed(2) : "";
                }
            };

            quantity?.addEventListener("input", calculateAmount);
            unitPrice?.addEventListener("input", calculateAmount);
            $(".js-expense-number").each(function () {
                $(this).rules("remove", "step");
            });
            calculateAmount();
        })();
    </script>
}
