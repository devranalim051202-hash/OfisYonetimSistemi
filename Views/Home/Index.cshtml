@{
    ViewData["Title"] = AppLanguage.IsEnglish(Context) ? "Home" : "Ana Sayfa";
}

<header class="public-header">
    <a class="brand-logo-link public-brand" asp-controller="Home" asp-action="Index">
        <img src="~/images/smart-office-logo-cropped.png" alt="Smart Office" class="brand-logo brand-logo-public" />
    </a>
    <nav class="public-header-actions" aria-label="Main actions">
        <partial name="_LanguageSelector" />
        <a class="btn btn-outline-primary" asp-controller="Account" asp-action="Login">@AppLanguage.T(Context, "Login")</a>
        <a class="btn btn-primary" asp-controller="Account" asp-action="Register">@AppLanguage.T(Context, "Register")</a>
    </nav>
</header>

<section class="premium-hero">
    <div class="hero-slider">
        <span style="background-image:url('/images/landing/hero-1.png')"></span>
        <span style="background-image:url('/images/landing/hero-2.png')"></span>
        <span style="background-image:url('/images/landing/hero-3.png')"></span>
        <span style="background-image:url('/images/landing/hero-4.png')"></span>
        <span style="background-image:url('/images/landing/hero-5.png')"></span>
    </div>

    <div class="hero-overlay"></div>

    <div class="hero-content">
        <p class="eyebrow">@AppLanguage.T(Context, "HomeHeroEyebrow")</p>
        <h1>@AppLanguage.T(Context, "HomeHeroTitle")</h1>
        <p class="hero-text">@AppLanguage.T(Context, "HomeHeroText")</p>

        <div class="hero-stats">
            <div>
                <strong>360</strong>
                <span>@(AppLanguage.IsEnglish(Context) ? "Office Management" : "Ofis Yonetimi")</span>
            </div>
            <div>
                <strong>ERP</strong>
                <span>@(AppLanguage.IsEnglish(Context) ? "Business Core" : "Kurumsal Altyapi")</span>
            </div>
            <div>
                <strong>@(AppLanguage.IsEnglish(Context) ? "One Panel" : "Tek Panel")</strong>
                <span>@(AppLanguage.IsEnglish(Context) ? "Project Tracking" : "Proje Takibi")</span>
            </div>
        </div>
    </div>
</section>

<section class="premium-intro">
    <p class="eyebrow">@AppLanguage.T(Context, "HomeIntroEyebrow")</p>
    <h2>@AppLanguage.T(Context, "HomeIntroTitle")</h2>
    <p>@AppLanguage.T(Context, "HomeIntroText")</p>
</section>

<section class="premium-grid">
    <article class="premium-card">
        <span>01</span>
        <h3>@(AppLanguage.IsEnglish(Context) ? "Project-Based Management" : "Proje Bazli Yonetim")</h3>
        <p>@(AppLanguage.IsEnglish(Context) ? "Connect expenses, apartments and documents directly to the related project." : "Giderleri, daireleri ve evraklari dogrudan ilgili projeye baglayin.")</p>
    </article>

    <article class="premium-card">
        <span>02</span>
        <h3>@(AppLanguage.IsEnglish(Context) ? "Expense Tracking" : "Gider Takibi")</h3>
        <p>@(AppLanguage.IsEnglish(Context) ? "Track project costs and receipts in a clear accounting workflow." : "Proje maliyetlerini ve fisleri anlasilir bir muhasebe akisiyle takip edin.")</p>
    </article>

    <article class="premium-card">
        <span>03</span>
        <h3>@(AppLanguage.IsEnglish(Context) ? "Personnel Roles" : "Personel Rolleri")</h3>
        <p>@(AppLanguage.IsEnglish(Context) ? "Separate admin, secretary, accounting and real estate permissions cleanly." : "Admin, sekreter, muhasebe ve emlak yetkilerini temiz sekilde ayirin.")</p>
    </article>

    <article class="premium-card">
        <span>04</span>
        <h3>@(AppLanguage.IsEnglish(Context) ? "Apartment Sales" : "Daire Satis")</h3>
        <p>@(AppLanguage.IsEnglish(Context) ? "Follow apartment status, sales and contract information from project details." : "Daire durumu, satis ve sozlesme bilgilerini proje detayindan takip edin.")</p>
    </article>
</section>

<section class="premium-band">
    <div>
        <p class="eyebrow">@AppLanguage.T(Context, "HomeForWhom")</p>
        <h2>@AppLanguage.T(Context, "HomeForWhomText")</h2>
    </div>

    <div class="premium-tags">
        <span>@(AppLanguage.IsEnglish(Context) ? "Contractors" : "Muteahhitler")</span>
        <span>@(AppLanguage.IsEnglish(Context) ? "Accounting Teams" : "Muhasebe Ekibi")</span>
        <span>@(AppLanguage.IsEnglish(Context) ? "Office Staff" : "Ofis Personeli")</span>
        <span>@(AppLanguage.IsEnglish(Context) ? "Project Managers" : "Proje Sorumlulari")</span>
    </div>
</section>

<section class="premium-cta">
    <h2>@AppLanguage.T(Context, "HomeCtaTitle")</h2>
    <p>@AppLanguage.T(Context, "HomeCtaText")</p>

    <div class="hero-actions">
        <a class="premium-btn primary" asp-controller="Account" asp-action="Login">@AppLanguage.T(Context, "Login")</a>
        <a class="premium-btn secondary" asp-controller="Account" asp-action="Register">@AppLanguage.T(Context, "Register")</a>
    </div>
</section>
