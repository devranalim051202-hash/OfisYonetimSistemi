@{
    ViewData["Title"] = "Admin Girişi";
}

<section class="auth-page">
    <div class="auth-panel">
        <a class="auth-back-link" asp-controller="Account" asp-action="Login">Giriş seçimine dön</a>
        <p class="eyebrow">Admin Paneli</p>
        <h1>Admin Girişi</h1>
        <p class="auth-help">Tam yetkili kullanıcılar sistem yönetimi için buradan giriş yapar.</p>

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success">@TempData["SuccessMessage"]</div>
        }

        @if (ViewBag.Message != null)
        {
            <div class="alert alert-info">@ViewBag.Message</div>
        }

        <form asp-controller="Account" asp-action="AdminLogin" method="post" class="auth-form">
            @Html.AntiForgeryToken()
            <div class="form-floating mb-3 position-relative">
                <input id="email" name="email" type="email" class="form-control ps-4" placeholder="admin@ornek.com" required>
                <label for="email" class="ps-4"><i class="bi bi-envelope me-2 text-muted"></i>E-posta Adresi</label>
            </div>
            <div class="form-floating mb-4 position-relative">
                <input id="password" name="password" type="password" class="form-control ps-4" placeholder="Şifrenizi girin" required>
                <label for="password" class="ps-4"><i class="bi bi-lock me-2 text-muted"></i>Şifre</label>
            </div>
            <button type="submit" class="btn btn-primary w-100 py-2 fs-5"><i class="bi bi-box-arrow-in-right me-2"></i>Admin Girişi Yap</button>
        </form>
    </div>
</section>
