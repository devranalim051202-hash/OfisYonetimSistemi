@{
    ViewData["Title"] = AppLanguage.T(Context, "PersonnelLogin");
}

<header class="public-header auth-topbar">
    <a class="brand-logo-link public-brand" asp-controller="Home" asp-action="Index">
        <img src="~/images/smart-office-logo-cropped.png" alt="Smart Office" class="brand-logo brand-logo-public" />
    </a>
    <div class="public-header-actions">
        <partial name="_LanguageSelector" />
    </div>
</header>

<section class="auth-split-page">
    <div class="auth-split-media">
        <div class="auth-split-caption">
            <span>Smart Office</span>
            <strong>@(AppLanguage.IsEnglish(Context) ? "Follow daily tasks in a clean and readable panel." : "Gunluk islemleri duzenli, hizli ve okunabilir bir panelden takip edin.")</strong>
        </div>
    </div>

    <div class="auth-split-content">
        <div class="auth-panel auth-split-panel">
            <a class="auth-back-link" asp-controller="Account" asp-action="Login">@AppLanguage.T(Context, "BackToLoginChoice")</a>
            <p class="eyebrow">@AppLanguage.T(Context, "PersonnelPanel")</p>
            <h1>@AppLanguage.T(Context, "PersonnelLogin")</h1>
            <p class="auth-help">@AppLanguage.T(Context, "PersonnelLoginHelp")</p>

            @if (ViewBag.Message != null)
            {
                <div class="alert alert-info">@ViewBag.Message</div>
            }

            <form asp-controller="Account" asp-action="PersonnelLogin" method="post" class="auth-form" autocomplete="off">
                @Html.AntiForgeryToken()
                <div class="form-floating mb-3 position-relative">
                    <input id="personnelEmail" name="email" type="email" class="form-control ps-4 js-clear-login-field" placeholder="personnel@example.com" autocomplete="off" autocapitalize="none" spellcheck="false" value="" required>
                    <label for="personnelEmail" class="ps-4"><i class="bi bi-envelope me-2 text-muted"></i>@AppLanguage.T(Context, "UserEmail")</label>
                </div>
                <div class="form-floating mb-4 position-relative">
                    <input id="personnelPassword" name="password" type="password" class="form-control ps-4 js-clear-login-field" placeholder='@AppLanguage.T(Context, "Password")' autocomplete="new-password" value="" required>
                    <label for="personnelPassword" class="ps-4"><i class="bi bi-lock me-2 text-muted"></i>@AppLanguage.T(Context, "Password")</label>
                </div>
                <button type="submit" class="btn btn-primary w-100 py-2 fs-5"><i class="bi bi-box-arrow-in-right me-2"></i>@AppLanguage.T(Context, "PersonnelLoginButton")</button>
            </form>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        window.addEventListener("pageshow", function () {
            document.querySelectorAll(".js-clear-login-field").forEach(function (input) {
                input.value = "";
            });
        });
    </script>
}
