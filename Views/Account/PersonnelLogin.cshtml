@{
    ViewData["Title"] = "Personel Girişi";
}

<section class="auth-page">
    <div class="auth-panel">
        <a class="auth-back-link" asp-controller="Account" asp-action="Login">Giriş seçimine dön</a>
        <p class="eyebrow">Personel Paneli</p>
        <h1>Personel Girişi</h1>
        <p class="auth-help">Ofis personeli günlük kayıt ve takip işlemleri için buradan giriş yapar.</p>

        @if (ViewBag.Message != null)
        {
            <div class="alert alert-info">@ViewBag.Message</div>
        }

        <form asp-controller="Account" asp-action="PersonnelLogin" method="post" class="auth-form">
            @Html.AntiForgeryToken()
            <div class="mb-3">
                <label for="email" class="form-label">E-posta</label>
                <input id="email" name="email" type="email" class="form-control" placeholder="personel@ornek.com" required>
            </div>
            <div class="mb-3">
                <label for="password" class="form-label">Şifre</label>
                <input id="password" name="password" type="password" class="form-control" placeholder="Şifrenizi girin" required>
            </div>
            <button type="submit" class="btn btn-primary w-100">Personel Girişi Yap</button>
        </form>
    </div>
</section>
