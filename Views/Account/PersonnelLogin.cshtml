@{
    ViewData["Title"] = "Personel Girisi";
}

<section class="auth-split-page">
    <div class="auth-split-media">
        <div class="auth-split-caption">
            <span>Akilli Ofis</span>
            <strong>Gunluk islemleri duzenli, hizli ve okunabilir bir panelden takip edin.</strong>
        </div>
    </div>

    <div class="auth-split-content">
        <div class="auth-panel auth-split-panel">
            <a class="auth-back-link" asp-controller="Account" asp-action="Login">Giris secimine don</a>
            <p class="eyebrow">Personel Paneli</p>
            <h1>Personel Girisi</h1>
            <p class="auth-help">Ofis personeli gunluk kayit ve takip islemleri icin buradan giris yapar.</p>

            @if (ViewBag.Message != null)
            {
                <div class="alert alert-info">@ViewBag.Message</div>
            }

            <form asp-controller="Account" asp-action="PersonnelLogin" method="post" class="auth-form" autocomplete="off">
                @Html.AntiForgeryToken()
                <div class="form-floating mb-3 position-relative">
                    <input id="personnelEmail" name="email" type="email" class="form-control ps-4 js-clear-login-field" placeholder="personel@ornek.com" autocomplete="off" autocapitalize="none" spellcheck="false" value="" required>
                    <label for="personnelEmail" class="ps-4"><i class="bi bi-envelope me-2 text-muted"></i>E-posta Adresi</label>
                </div>
                <div class="form-floating mb-4 position-relative">
                    <input id="personnelPassword" name="password" type="password" class="form-control ps-4 js-clear-login-field" placeholder="Sifrenizi girin" autocomplete="new-password" value="" required>
                    <label for="personnelPassword" class="ps-4"><i class="bi bi-lock me-2 text-muted"></i>Sifre</label>
                </div>
                <button type="submit" class="btn btn-primary w-100 py-2 fs-5"><i class="bi bi-box-arrow-in-right me-2"></i>Personel Girisi Yap</button>
            </form>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        window.addEventListener("pageshow", function () {
            document.querySelectorAll(".js-clear-login-field").forEach(function (input) {
                input.value = "";
            });
        });
    </script>
}
