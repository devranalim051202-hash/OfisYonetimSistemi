<!DOCTYPE html>
@inject IConfiguration Configuration
@{
    var roleName = Context.Session.GetString("RoleName");
    var fullName = Context.Session.GetString("FullName");
    var companyName = Context.Session.GetString("CompanyName");
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? "";
    var isAuthFlow = string.Equals(currentController, "Account", StringComparison.OrdinalIgnoreCase)
        && new[] { "Login", "AdminLogin", "PersonnelLogin", "Register", "VerifyEmail" }
            .Contains(currentAction, StringComparer.OrdinalIgnoreCase);
    var isLoggedIn = !string.IsNullOrEmpty(roleName) && !isAuthFlow;
    var isManager = roleName == "Admin" || roleName == "Mudur";
    var homeController = isManager ? "Manager" : "Personnel";
    var pageLanguage = AppLanguage.IsEnglish(Context) ? "en" : "tr";

    Func<string, bool> isActiveController = controller =>
        string.Equals(currentController, controller, StringComparison.OrdinalIgnoreCase);

    var isDashboardActive = isActiveController(homeController)
        || isActiveController("Manager") && currentAction == "Index"
        || isActiveController("Personnel") && currentAction == "Index";
}
<html lang="@pageLanguage">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Smart Office</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/OfisYonetimSistemi.styles.css" asp-append-version="true" />
</head>
<body class="@(isLoggedIn ? "app-body" : "public-body")">
    @if (isLoggedIn)
    {
        <div class="app-shell">
            <div class="app-mobile-bar d-lg-none">
                <button class="btn app-menu-button" type="button" data-bs-toggle="offcanvas" data-bs-target="#appSidebar" aria-controls="appSidebar" aria-label="Menu">
                    <span class="app-menu-lines"></span>
                </button>
                <a class="app-mobile-brand brand-logo-link" asp-controller="@homeController" asp-action="Index">
                    <img src="~/images/smart-office-logo-cropped.png" alt="Smart Office" class="brand-logo brand-logo-mobile" />
                </a>
                <span class="app-mobile-user">@fullName</span>
            </div>

            <aside class="app-sidebar offcanvas-lg offcanvas-start" tabindex="-1" id="appSidebar" aria-labelledby="appSidebarLabel">
                <div class="offcanvas-header app-sidebar-header d-lg-none">
                    <h5 class="offcanvas-title" id="appSidebarLabel">Smart Office</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="offcanvas" data-bs-target="#appSidebar" aria-label="Close"></button>
                </div>

                <div class="offcanvas-body app-sidebar-body">
                    <div class="sidebar-brand d-none d-lg-block">
                        <a asp-controller="@homeController" asp-action="Index">
                            <img src="~/images/smart-office-logo-cropped.png" alt="Smart Office" class="brand-logo brand-logo-sidebar" />
                        </a>
                    </div>

                    <nav class="sidebar-nav" aria-label="Panel menu">
                        <span class="sidebar-section-title">@AppLanguage.T(Context, "Panel")</span>
                        <a class="sidebar-link @(isDashboardActive ? "active" : "")" asp-controller="@homeController" asp-action="Index">
                            <span class="sidebar-icon"><i class="bi bi-grid-1x2-fill"></i></span>
                            @AppLanguage.T(Context, "Dashboard")
                        </a>
                        <a class="sidebar-link @(isActiveController("Projects") ? "active" : "")" asp-controller="Projects" asp-action="Index">
                            <span class="sidebar-icon"><i class="bi bi-briefcase-fill"></i></span>
                            @AppLanguage.T(Context, "Projects")
                        </a>

                        <span class="sidebar-section-title">@AppLanguage.T(Context, "Management")</span>
                        @if (isManager)
                        {
                            <a class="sidebar-link @(isActiveController("Manager") && currentAction == "Personnel" ? "active" : "")" asp-controller="Manager" asp-action="Personnel">
                                <span class="sidebar-icon"><i class="bi bi-people-fill"></i></span>
                                @AppLanguage.T(Context, "Personnel")
                            </a>
                        }
                        <a class="sidebar-link @(isActiveController("Assistant") ? "active" : "")" asp-controller="Assistant" asp-action="Index">
                            <span class="sidebar-icon"><img src="~/images/smartoffice-ai-icon.png" alt="" class="sidebar-ai-icon" /></span>
                            @AppLanguage.T(Context, "Assistant")
                        </a>
                    </nav>

                    <div class="sidebar-settings">
                        <span class="sidebar-section-title">@AppLanguage.T(Context, "Settings")</span>
                        <div class="sidebar-language">
                            <span class="sidebar-language-label">@AppLanguage.T(Context, "Language")</span>
                            <partial name="_LanguageSelector" />
                        </div>
                        <div class="sidebar-profile">
                            <span class="sidebar-user-avatar">@(!string.IsNullOrWhiteSpace(fullName) ? fullName.Substring(0, 1).ToUpper() : "U")</span>
                            <span>
                                <strong>@fullName</strong>
                                <small>@roleName</small>
                                @if (!string.IsNullOrWhiteSpace(companyName))
                                {
                                    <small>@companyName</small>
                                }
                            </span>
                        </div>
                        <a class="sidebar-logout" asp-controller="Account" asp-action="Logout"><i class="bi bi-box-arrow-right me-2"></i> @AppLanguage.T(Context, "SignOut")</a>
                    </div>
                </div>
            </aside>

            <div class="app-main">
                <div class="app-topbar">
                    <div>
                        <h1>@(!string.IsNullOrWhiteSpace(companyName) ? companyName : "Smart Office")</h1>
                    </div>
                    <div class="app-topbar-actions">
                        <span class="app-status-pill">@AppLanguage.T(Context, "ActiveSystem")</span>
                        <span class="app-date-pill">@DateTime.Now.ToString("dd.MM.yyyy")</span>
                    </div>
                </div>

                <main role="main" class="app-content">
                    @RenderBody()
                </main>

                <footer class="app-footer">
                    &copy; 2026 - Smart Office
                </footer>

                @if (!isActiveController("Assistant"))
                {
                    <a class="assistant-shortcut" asp-controller="Assistant" asp-action="Index" aria-label='@AppLanguage.T(Context, "Assistant")'>
                        <img src="~/images/smartoffice-ai-icon.png" alt="" />
                        <span>@AppLanguage.T(Context, "Assistant")</span>
                    </a>
                }
            </div>
        </div>
    }
    else
    {
        <div class="container">
            <main role="main" class="pb-3">
                @RenderBody()
            </main>
        </div>

        <footer class="border-top footer text-muted public-footer">
            <div class="container public-footer-inner">
                <span class="public-footer-copy">&copy; 2026 - Smart Office</span>
                <img src="~/images/smart-office-logo-cropped.png" alt="Smart Office" class="public-footer-logo" />
                <span class="public-footer-rights">@AppLanguage.T(Context, "AllRights")</span>
            </div>
        </footer>
    }

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @{
        var tawkEnabled = Configuration.GetValue<bool>("TawkTo:Enabled");
        var tawkPropertyId = Configuration["TawkTo:PropertyId"];
        var tawkWidgetId = Configuration["TawkTo:WidgetId"];
    }
    @if (tawkEnabled && !string.IsNullOrWhiteSpace(tawkPropertyId) && !string.IsNullOrWhiteSpace(tawkWidgetId))
    {
        <script>
            var Tawk_API = Tawk_API || {};
            var Tawk_LoadStart = new Date();
            (function () {
                var s1 = document.createElement("script");
                var s0 = document.getElementsByTagName("script")[0];
                s1.async = true;
                s1.src = "https://embed.tawk.to/@tawkPropertyId/@tawkWidgetId";
                s1.charset = "UTF-8";
                s1.setAttribute("crossorigin", "*");
                s0.parentNode.insertBefore(s1, s0);
            })();
        </script>
    }
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
