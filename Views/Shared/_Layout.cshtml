<!DOCTYPE html>
@{
    var roleName = Context.Session.GetString("RoleName");
    var fullName = Context.Session.GetString("FullName");
    var companyName = Context.Session.GetString("CompanyName");
    var isLoggedIn = !string.IsNullOrEmpty(roleName);
    var isManager = roleName == "Admin" || roleName == "Mudur";
    var homeController = isManager ? "Manager" : "Personnel";
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? "";

    Func<string, bool> isActiveController = controller =>
        string.Equals(currentController, controller, StringComparison.OrdinalIgnoreCase);

    var isDashboardActive = isActiveController(homeController)
        || isActiveController("Manager") && currentAction == "Index"
        || isActiveController("Personnel") && currentAction == "Index";
}
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Ofis Yönetim Sistemi</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/OfisYonetimSistemi.styles.css" asp-append-version="true" />
</head>
<body class="@(isLoggedIn ? "app-body" : "public-body")">
    @if (isLoggedIn)
    {
        <div class="app-shell">
            <div class="app-mobile-bar d-lg-none">
                <button class="btn app-menu-button" type="button" data-bs-toggle="offcanvas" data-bs-target="#appSidebar" aria-controls="appSidebar" aria-label="Menüyü aç">
                    <span class="app-menu-lines"></span>
                </button>
                <a class="app-mobile-brand" asp-controller="@homeController" asp-action="Index">Ofis Yönetim</a>
                <span class="app-mobile-user">@fullName</span>
            </div>

            <aside class="app-sidebar offcanvas-lg offcanvas-start" tabindex="-1" id="appSidebar" aria-labelledby="appSidebarLabel">
                <div class="offcanvas-header app-sidebar-header d-lg-none">
                    <h5 class="offcanvas-title" id="appSidebarLabel">Ofis Yönetim</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="offcanvas" data-bs-target="#appSidebar" aria-label="Kapat"></button>
                </div>

                <div class="offcanvas-body app-sidebar-body">
                    <div class="sidebar-brand d-none d-lg-block">
                        <a asp-controller="@homeController" asp-action="Index">
                            <span class="sidebar-brand-mark">O</span>
                            <span>
                                <strong>Ofis Yönetim</strong>
                                <small>Proje Paneli</small>
                            </span>
                        </a>
                    </div>

                    <nav class="sidebar-nav" aria-label="Panel menüsü">
                        <span class="sidebar-section-title">Panel</span>
                        <a class="sidebar-link @(isDashboardActive ? "active" : "")" asp-controller="@homeController" asp-action="Index">
                            <span class="sidebar-icon">D</span>
                            Dashboard
                        </a>
                        <a class="sidebar-link @(isActiveController("Projects") ? "active" : "")" asp-controller="Projects" asp-action="Index">
                            <span class="sidebar-icon">P</span>
                            Projeler
                        </a>

                        <span class="sidebar-section-title">Yönetim</span>
                        @if (isManager)
                        {
                            <a class="sidebar-link @(isActiveController("Manager") && currentAction != "Index" ? "active" : "")" asp-controller="Manager" asp-action="Index">
                                <span class="sidebar-icon">K</span>
                                Personeller
                            </a>
                        }
                        <a class="sidebar-link @(isActiveController("Assistant") ? "active" : "")" asp-controller="Assistant" asp-action="Index">
                            <span class="sidebar-icon">AI</span>
                            AI Asistan
                        </a>
                    </nav>

                    <div class="sidebar-settings">
                        <span class="sidebar-section-title">Ayarlar</span>
                        <div class="sidebar-profile">
                            <span class="sidebar-user-avatar">@(!string.IsNullOrWhiteSpace(fullName) ? fullName.Substring(0, 1).ToUpper() : "U")</span>
                            <span>
                                <strong>@fullName</strong>
                                <small>@roleName</small>
                                @if (!string.IsNullOrWhiteSpace(companyName))
                                {
                                    <small>@companyName</small>
                                }
                            </span>
                        </div>
                        <a class="sidebar-logout" asp-controller="Account" asp-action="Logout">Sistemden Çıkış Yap</a>
                    </div>
                </div>
            </aside>

            <div class="app-main">
                <div class="app-topbar">
                    <div>
                        <span class="app-kicker">Ofis Otomasyon Paneli</span>
                        <h1>@(ViewData["Title"] ?? "Dashboard")</h1>
                    </div>
                    <div class="app-topbar-actions">
                        <span class="app-status-pill">Aktif Sistem</span>
                        <span class="app-date-pill">@DateTime.Now.ToString("dd.MM.yyyy")</span>
                    </div>
                </div>

                <main role="main" class="app-content">
                    @RenderBody()
                </main>

                <footer class="app-footer">
                    &copy; 2026 - Ofis Yönetim Sistemi
                </footer>
            </div>
        </div>
    }
    else
    {
        <div class="container">
            <main role="main" class="pb-3">
                @RenderBody()
            </main>
        </div>

        <footer class="border-top footer text-muted">
            <div class="container">
                &copy; 2026 - Ofis Yönetim Sistemi
            </div>
        </footer>
    }

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
