@{
    ViewData["Title"] = "AI Asistan";
}

<section class="dashboard-page">
    <div class="dashboard-header ai-hero-panel">
        <div>
            <p class="eyebrow">AI Asistan</p>
            <h1>Akilli ofis yardimcisi</h1>
            <p>Proje, gider ve evrak sureclerinde ekip kararlarini hizlandiracak asistan alani burada konumlandirilacak.</p>
        </div>
    </div>

    <div class="assistant-preview">
        <div class="assistant-orb">AI</div>
        <div>
            <span class="premium-panel-label">Hazirlik Modu</span>
            <h2>Yakinda aktif olacak</h2>
            <p>Bu ekran su an panel navigasyonunun calismasi icin hazirlandi. Ilerleyen adimda proje ozetleri, gider yorumlari ve evrak hatirlatmalari buradan yonetilebilir.</p>
        </div>
        <a class="btn btn-primary" asp-controller="Projects" asp-action="Index">Projelere Don</a>
    </div>
</section>
