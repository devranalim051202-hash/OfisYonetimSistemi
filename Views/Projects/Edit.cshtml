@model OfisYonetimSistemi.Models.ViewModels.ProjectFormViewModel

@{
    var isEnglish = AppLanguage.IsEnglish(Context);
    ViewData["Title"] = isEnglish ? "Edit Project" : "Proje Duzenle";
}

<section class="form-page">
    <div class="form-panel">
        <a class="auth-back-link" asp-controller="Projects" asp-action="Index">@(isEnglish ? "Back to Projects" : "Projelere don")</a>
        <p class="eyebrow">@(isEnglish ? "Project Management" : "Proje Yonetimi")</p>
        <h1>@(isEnglish ? "Edit Project" : "Proje duzenle")</h1>
        <p class="auth-help">@(isEnglish ? "Update project information, dates and status." : "Proje bilgilerini, tarihlerini ve durumunu guncelleyin.")</p>

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success"><i class="bi bi-check-circle-fill me-2"></i>@TempData["SuccessMessage"]</div>
        }

        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger"><i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["ErrorMessage"]</div>
        }

        <form asp-controller="Projects" asp-action="Edit" asp-route-id="@Model.Id" method="post" enctype="multipart/form-data" class="row g-3">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="CreatedAt" />
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <partial name="_ProjectForm" model="Model" />

            <div class="col-12">
                <button type="submit" class="btn btn-primary">@(isEnglish ? "Update" : "Guncelle")</button>
            </div>
        </form>
    </div>
</section>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
