@model OfisYonetimSistemi.Models.ViewModels.ProjectFormViewModel

<div class="col-md-8">
    <div class="form-floating position-relative">
        <input asp-for="Name" class="form-control ps-4" placeholder="Proje adi">
        <label asp-for="Name" class="ps-4"><i class="bi bi-building me-2 text-muted"></i>Proje Adı</label>
    </div>
    <span asp-validation-for="Name" class="text-danger small"></span>
</div>

<div class="col-md-4">
    <div class="form-floating position-relative">
        <select asp-for="Status" asp-items="ViewBag.Statuses" class="form-select ps-4"></select>
        <label asp-for="Status" class="ps-4"><i class="bi bi-activity me-2 text-muted"></i>Durum</label>
    </div>
    <span asp-validation-for="Status" class="text-danger small"></span>
</div>

<div class="col-md-12">
    <div class="form-floating position-relative">
        <input asp-for="Location" class="form-control ps-4" placeholder="Konum">
        <label asp-for="Location" class="ps-4"><i class="bi bi-geo-alt me-2 text-muted"></i>Konum</label>
    </div>
    <span asp-validation-for="Location" class="text-danger small"></span>
</div>

<div class="col-md-6">
    <div class="form-floating position-relative">
        <input asp-for="StartDate" type="date" class="form-control ps-4">
        <label asp-for="StartDate" class="ps-4"><i class="bi bi-calendar-event me-2 text-muted"></i>Başlangıç Tarihi</label>
    </div>
    <span asp-validation-for="StartDate" class="text-danger small"></span>
</div>

<div class="col-md-6">
    <div class="form-floating position-relative">
        <input asp-for="EndDate" type="date" class="form-control ps-4">
        <label asp-for="EndDate" class="ps-4"><i class="bi bi-calendar-x me-2 text-muted"></i>Bitiş Tarihi</label>
    </div>
    <span asp-validation-for="EndDate" class="text-danger small"></span>
</div>

<div class="col-md-6">
    <label asp-for="FloorCount" class="form-label">Kat sayisi</label>
    <input asp-for="FloorCount" type="number" min="0" class="form-control">
    <span asp-validation-for="FloorCount" class="text-danger"></span>
</div>

<div class="col-md-6">
    <label asp-for="ApartmentCount" class="form-label">Daire sayisi</label>
    <input asp-for="ApartmentCount" type="number" min="0" class="form-control">
    <span asp-validation-for="ApartmentCount" class="text-danger"></span>
</div>

<div class="col-md-12">
    <div class="form-floating position-relative">
        <textarea asp-for="Description" class="form-control ps-4" style="height: 100px" placeholder="Aciklama"></textarea>
        <label asp-for="Description" class="ps-4"><i class="bi bi-card-text me-2 text-muted"></i>Açıklama</label>
    </div>
    <span asp-validation-for="Description" class="text-danger small"></span>
</div>

@if (Model.ExistingImages.Any())
{
    <div class="col-md-12">
        <label class="form-label">Mevcut proje gorselleri</label>
        <div class="row g-3">
            @foreach (var image in Model.ExistingImages)
            {
                <div class="col-md-4">
                    <div class="border rounded p-2 h-100">
                        <img src="@image.FilePath" alt="@image.OriginalFileName" class="img-fluid rounded mb-2" style="height: 140px; width: 100%; object-fit: cover;">
                        <div class="form-check">
                            <input class="form-check-input" type="radio" asp-for="CoverImageId" value="@image.Id" id="cover_@image.Id">
                            <label class="form-check-label" for="cover_@image.Id">Kapak gorseli</label>
                        </div>
                        <button type="submit"
                                class="btn btn-outline-danger btn-sm mt-2"
                                formaction="@Url.Action("DeleteImage", "Projects", new { id = image.Id })"
                                formmethod="post"
                                formnovalidate>
                            Sil
                        </button>
                    </div>
                </div>
            }
        </div>
        <span asp-validation-for="CoverImageId" class="text-danger"></span>
    </div>
}

<div class="col-md-12">
    <label asp-for="ProjectImages" class="form-label">Proje görselleri <span class="text-muted fw-normal">(isteğe bağlı)</span></label>
    <div class="project-upload-box">
        <div>
            <strong><i class="bi bi-images me-2"></i>Fotoğraf ekle</strong>
            <p>İsterseniz projeye bir veya birden fazla görsel ekleyebilirsiniz.</p>
        </div>
        <input asp-for="ProjectImages" type="file" accept=".jpg,.jpeg,.png,.webp,image/jpeg,image/png,image/webp" multiple class="form-control">
    </div>
    <div class="form-text">Fotoğraf yüklemek zorunlu değildir. JPG, PNG veya WEBP dosyası yükleyebilirsiniz. Her dosya en fazla 5 MB olabilir.</div>
    <span asp-validation-for="ProjectImages" class="text-danger"></span>
</div>

<div class="col-md-12">
    <div class="form-check">
        <input asp-for="MakeFirstImageCover" class="form-check-input">
        <label asp-for="MakeFirstImageCover" class="form-check-label">Yuklenen ilk gorseli kapak yap</label>
    </div>
</div>
