@model OfisYonetimSistemi.Models.Project

@{
    ViewData["Title"] = "Proje Sil";
}

<section class="auth-page">
    <div class="auth-panel">
        <a class="auth-back-link" asp-controller="Projects" asp-action="Index">Projelere don</a>
        <p class="eyebrow">Proje Yonetimi</p>
        <h1>Proje sil</h1>
        <p class="auth-help">
            <strong>@Model.Name</strong> projesini silmek istediginize emin misiniz?
            Bagli stok hareketi veya evrak varsa sistem silmeye izin vermez.
        </p>

        <form asp-controller="Projects" asp-action="Delete" asp-route-id="@Model.Id" method="post">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-danger w-100">Evet, projeyi sil</button>
        </form>
    </div>
</section>
