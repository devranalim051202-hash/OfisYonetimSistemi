@model OfisYonetimSistemi.Models.Project

@{
    ViewData["Title"] = "Proje Detay";
    decimal totalExpense = ViewBag.TotalExpense ?? 0m;
    decimal directExpenseTotal = ViewBag.DirectExpenseTotal ?? 0m;
    bool canManageApartmentSales = ViewBag.CanManageApartmentSales ?? false;
    var maxApartmentColumnCount = Model.Apartments.Any()
        ? Model.Apartments.GroupBy(a => a.FloorNumber).Max(g => g.Count())
        : 0;
    var remainingText = "-";

    if (Model.EndDate.HasValue)
    {
        var today = DateTime.Today;
        var endDate = Model.EndDate.Value.Date;

        if (endDate < today)
        {
            remainingText = "Suresi doldu";
        }
        else
        {
            var cursor = today;
            var months = 0;

            while (cursor.AddMonths(1) <= endDate)
            {
                cursor = cursor.AddMonths(1);
                months++;
            }

            var days = (endDate - cursor).Days;
            remainingText = $"{months} ay {days} gun";
        }
    }
}

<section class="dashboard-page">
    <div class="dashboard-header">
        <div>
            <p class="eyebrow">Proje Detay</p>
            <h1>@Model.Name</h1>
            <p>@(Model.Description ?? "Bu proje icin aciklama girilmemis.")</p>
        </div>
        <div class="hero-actions">
            <a class="btn btn-outline-secondary" asp-controller="Projects" asp-action="Index">Projelere Don</a>
            <a class="btn btn-primary" asp-controller="Projects" asp-action="Edit" asp-route-id="@Model.Id">Duzenle</a>
        </div>
    </div>

    <div class="detail-grid">
        <div class="detail-card">
            <span>Durum</span>
            <strong>@Model.Status</strong>
        </div>
        <div class="detail-card">
            <span>Baslangic</span>
            <strong>@Model.StartDate.ToString("dd.MM.yyyy")</strong>
        </div>
        <div class="detail-card">
            <span>Bitis</span>
            <strong>@(Model.EndDate?.ToString("dd.MM.yyyy") ?? "-")</strong>
        </div>
        <div class="detail-card">
            <span>Toplam gider</span>
            <strong>@totalExpense.ToString("N2") TL</strong>
        </div>
        <div class="detail-card">
            <span>Kalan sure</span>
            <strong>@remainingText</strong>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">@TempData["SuccessMessage"]</div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
    }

    <div class="detail-section">
        <div class="table-panel">
            <div class="table-panel-header">
                <h2>Proje ozeti</h2>
            </div>
            @if (Model.ProjectImages.Any())
            {
                var coverImage = Model.ProjectImages.FirstOrDefault(i => i.IsCover) ?? Model.ProjectImages.First();
                <img src="@coverImage.FilePath" alt="@Model.Name" class="img-fluid rounded mb-3" style="max-height: 360px; width: 100%; object-fit: cover;">
            }
            <dl class="project-info-list">
                <dt>Proje adi</dt>
                <dd>@Model.Name</dd>
                <dt>Konum</dt>
                <dd>@(Model.Location ?? "-")</dd>
                <dt>Baslangic tarihi</dt>
                <dd>@Model.StartDate.ToString("dd.MM.yyyy")</dd>
                <dt>Bitis tarihi</dt>
                <dd>@(Model.EndDate?.ToString("dd.MM.yyyy") ?? "-")</dd>
                <dt>Bitmesine kalan</dt>
                <dd>@remainingText</dd>
                <dt>Kayit tarihi</dt>
                <dd>@Model.CreatedAt.ToString("dd.MM.yyyy HH:mm")</dd>
                <dt>Proje gider toplami</dt>
                <dd>@directExpenseTotal.ToString("N2") TL</dd>
                <dt>Kat / daire sayisi</dt>
                <dd>@Model.FloorCount kat / @Model.ApartmentCount daire</dd>
            </dl>
        </div>
    </div>

    <div class="detail-section">
        <div class="table-panel">
            <div class="table-panel-header">
                <h2>Daire satis takip tablosu</h2>
            </div>
            @if (!Model.Apartments.Any())
            {
                <p>Bu proje icin daire kaydi bulunmuyor.</p>
            }
            else
            {
                @if (canManageApartmentSales)
                {
                    <form asp-controller="Projects" asp-action="BulkUpdateApartmentRoomType" method="post" class="row g-2 align-items-end mb-3">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="projectId" value="@Model.Id" />
                        <div class="col-md-3">
                            <label class="form-label">Secim tipi</label>
                            <select name="selectionType" class="form-select">
                                <option value="column">Sutun sec</option>
                                <option value="row">Satir sec</option>
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Satir / sutun no</label>
                            <input name="selectionNumber" type="number" min="1" class="form-control" value="1">
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Oda tipi</label>
                            <input name="roomType" class="form-control" placeholder="2+1, 3+1, 4+1">
                        </div>
                        <div class="col-md-3">
                            <button type="submit" class="btn btn-primary w-100">Oda Tipini Guncelle</button>
                        </div>
                    </form>
                }
                <div class="table-responsive">
                    <table class="table table-bordered align-middle text-center">
                        <thead>
                            <tr>
                                <th>Kat</th>
                                @for (var i = 1; i <= maxApartmentColumnCount; i++)
                                {
                                    <th>Sutun @i</th>
                                }
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var floorGroup in Model.Apartments.GroupBy(a => a.FloorNumber).OrderByDescending(g => g.Key))
                            {
                                <tr>
                                    <th>@floorGroup.Key. Kat</th>
                                    @foreach (var apartment in floorGroup.OrderBy(a => a.ApartmentNumber))
                                    {
                                        var cellColor = apartment.IsSold ? "#198754" : "#ffffff";
                                        var textColor = apartment.IsSold ? "#ffffff" : "#111111";
                                        <td style="background-color:@cellColor; color:@textColor;">
                                            @if (canManageApartmentSales)
                                            {
                                                <a asp-controller="Apartments" asp-action="Details" asp-route-id="@apartment.Id" style="display:block; color:inherit; text-decoration:none;">
                                                    <strong>No @apartment.ApartmentNumber</strong><br>
                                                    <span>@apartment.RoomType</span><br>
                                                    <span>@apartment.Price.ToString("N0") TL</span><br>
                                                    <span>@(apartment.IsSold ? "SATILDI" : "BOS")</span>
                                                </a>
                                            }
                                            else
                                            {
                                                <strong>No @apartment.ApartmentNumber</strong><br>
                                                <span>@apartment.RoomType</span><br>
                                                <span>@apartment.Price.ToString("N0") TL</span><br>
                                                <span>@(apartment.IsSold ? "SATILDI" : "BOS")</span>
                                            }
                                        </td>
                                    }
                                    @for (var emptyIndex = floorGroup.Count(); emptyIndex < maxApartmentColumnCount; emptyIndex++)
                                    {
                                        <td></td>
                                    }
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>

    <div class="detail-section">
        <div class="table-panel">
            <div class="table-panel-header">
                <h2>Projeye ait gider ve belgeler</h2>
                <a class="btn btn-outline-primary btn-sm" asp-controller="Expenses" asp-action="Create" asp-route-projectId="@Model.Id">Gider Ekle</a>
            </div>
            <div class="table-responsive">
                <table class="table align-middle">
                    <thead>
                        <tr>
                            <th>Alinan malzeme</th>
                            <th>Firma / tedarikci</th>
                            <th>Miktar</th>
                            <th>Birim fiyat</th>
                            <th>Toplam fiyat</th>
                            <th>Fis / belge</th>
                            <th>Tarih</th>
                            <th class="text-end">Islem</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var expense in Model.Expenses.OrderByDescending(e => e.ExpenseDate))
                        {
                            <tr>
                                <td>@expense.Title</td>
                                <td>@expense.SupplierName</td>
                                <td>@expense.Quantity.ToString("N2")</td>
                                <td>@expense.UnitPrice.ToString("N2") TL</td>
                                <td>@expense.Amount.ToString("N2") TL</td>
                                <td>
                                    @if (!string.IsNullOrWhiteSpace(expense.DocumentFilePath))
                                    {
                                        <a href="@expense.DocumentFilePath" target="_blank">Fis / belge</a>
                                    }
                                    else
                                    {
                                        <span class="text-muted">Yok</span>
                                    }
                                </td>
                                <td>@expense.ExpenseDate.ToString("dd.MM.yyyy")</td>
                                <td class="text-end">
                                    <a class="btn btn-outline-secondary btn-sm" asp-controller="Expenses" asp-action="Edit" asp-route-id="@expense.Id">Duzenle</a>
                                    <a class="btn btn-outline-danger btn-sm" asp-controller="Expenses" asp-action="Delete" asp-route-id="@expense.Id">Sil</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</section>
