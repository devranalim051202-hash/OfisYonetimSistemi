@model OfisYonetimSistemi.Models.Project

@{
    ViewData["Title"] = "Proje Detay";
    decimal totalExpense = ViewBag.TotalExpense ?? 0m;
    decimal directExpenseTotal = ViewBag.DirectExpenseTotal ?? 0m;
    var remainingText = "-";

    if (Model.EndDate.HasValue)
    {
        var today = DateTime.Today;
        var endDate = Model.EndDate.Value.Date;

        if (endDate < today)
        {
            remainingText = "Suresi doldu";
        }
        else
        {
            var cursor = today;
            var months = 0;

            while (cursor.AddMonths(1) <= endDate)
            {
                cursor = cursor.AddMonths(1);
                months++;
            }

            var days = (endDate - cursor).Days;
            remainingText = $"{months} ay {days} gun";
        }
    }
}

<section class="dashboard-page">
    <div class="dashboard-header border-bottom pb-3 mb-4">
        <div>
            <p class="eyebrow"><i class="bi bi-info-circle me-2"></i>Proje Detay</p>
            <h1>@Model.Name</h1>
            <p class="text-muted">@(Model.Description ?? "Bu proje icin aciklama girilmemis.")</p>
        </div>
        <div class="hero-actions">
            <a class="btn btn-outline-secondary shadow-sm" asp-controller="Projects" asp-action="Index"><i class="bi bi-arrow-left me-2"></i>Projelere Don</a>
            <a class="btn btn-primary shadow-sm" asp-controller="Projects" asp-action="Edit" asp-route-id="@Model.Id"><i class="bi bi-pencil-square me-2"></i>Duzenle</a>
        </div>
    </div>

    <div class="detail-grid mb-5">
        <div class="detail-card position-relative overflow-hidden">
            <i class="bi bi-activity position-absolute text-primary opacity-25" style="font-size: 3rem; right: -10px; bottom: -10px;"></i>
            <span><i class="bi bi-circle-fill me-2 text-primary" style="font-size: 0.5rem; vertical-align: middle;"></i>Durum</span>
            <strong>@Model.Status</strong>
        </div>
        <div class="detail-card position-relative overflow-hidden">
            <i class="bi bi-calendar-event position-absolute text-success opacity-25" style="font-size: 3rem; right: -10px; bottom: -10px;"></i>
            <span><i class="bi bi-calendar-check me-2 text-success"></i>Baslangic</span>
            <strong>@Model.StartDate.ToString("dd.MM.yyyy")</strong>
        </div>
        <div class="detail-card position-relative overflow-hidden">
            <i class="bi bi-calendar-x position-absolute text-danger opacity-25" style="font-size: 3rem; right: -10px; bottom: -10px;"></i>
            <span><i class="bi bi-calendar-x me-2 text-danger"></i>Bitis</span>
            <strong>@(Model.EndDate?.ToString("dd.MM.yyyy") ?? "-")</strong>
        </div>
        <div class="detail-card position-relative overflow-hidden">
            <i class="bi bi-cash-stack position-absolute text-warning opacity-25" style="font-size: 3rem; right: -10px; bottom: -10px;"></i>
            <span><i class="bi bi-wallet2 me-2 text-warning"></i>Toplam gider</span>
            <strong>@totalExpense.ToString("N2") TL</strong>
        </div>
        <div class="detail-card position-relative overflow-hidden">
            <i class="bi bi-hourglass-split position-absolute text-info opacity-25" style="font-size: 3rem; right: -10px; bottom: -10px;"></i>
            <span><i class="bi bi-clock-history me-2 text-info"></i>Kalan sure</span>
            <strong>@remainingText</strong>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">@TempData["SuccessMessage"]</div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
    }

    <div class="detail-section">
        <div class="table-panel shadow-sm">
            <div class="table-panel-header border-bottom pb-2 mb-3">
                <h2><i class="bi bi-card-text me-2"></i>Proje özeti</h2>
            </div>
            <dl class="project-info-list">
                <dt>Proje adi</dt>
                <dd>@Model.Name</dd>
                <dt>Konum</dt>
                <dd>@(Model.Location ?? "-")</dd>
                <dt>Baslangic tarihi</dt>
                <dd>@Model.StartDate.ToString("dd.MM.yyyy")</dd>
                <dt>Bitis tarihi</dt>
                <dd>@(Model.EndDate?.ToString("dd.MM.yyyy") ?? "-")</dd>
                <dt>Bitmesine kalan</dt>
                <dd>@remainingText</dd>
                <dt>Kayit tarihi</dt>
                <dd>@Model.CreatedAt.ToString("dd.MM.yyyy HH:mm")</dd>
                <dt>Proje gider toplami</dt>
                <dd>@directExpenseTotal.ToString("N2") TL</dd>
            </dl>
        </div>
    </div>

    <div class="detail-section">
        <div class="table-panel shadow-sm">
            <div class="table-panel-header border-bottom pb-2 mb-3">
                <h2><i class="bi bi-receipt me-2"></i>Projeye ait giderler</h2>
                <a class="btn btn-outline-primary btn-sm" asp-controller="Expenses" asp-action="Create" asp-route-projectId="@Model.Id"><i class="bi bi-plus-lg me-1"></i>Gider Ekle</a>
            </div>
            <div class="table-responsive">
                <table class="table align-middle">
                    <thead>
                        <tr>
                            <th>Malzeme / urun</th>
                            <th>Firma / tedarikci</th>
                            <th>Miktar</th>
                            <th>Birim fiyat</th>
                            <th>Toplam fiyat</th>
                            <th>Tarih</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var expense in Model.Expenses.OrderByDescending(e => e.ExpenseDate))
                        {
                            <tr>
                                <td>@expense.Title</td>
                                <td>@(expense.SupplierName ?? "-")</td>
                                <td>@expense.Quantity.ToString("N2")</td>
                                <td>@expense.UnitPrice.ToString("N2") TL</td>
                                <td>@expense.Amount.ToString("N2") TL</td>
                                <td>@expense.ExpenseDate.ToString("dd.MM.yyyy")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="detail-section">
        <div class="table-panel shadow-sm">
            <div class="table-panel-header border-bottom pb-2 mb-3">
                <h2><i class="bi bi-file-earmark-text me-2"></i>Projeye ait evraklar ve belgeler</h2>
                <a class="btn btn-outline-primary btn-sm" asp-controller="Projects" asp-action="AddDocument" asp-route-projectId="@Model.Id"><i class="bi bi-file-earmark-plus me-1"></i>Belge Ekle</a>
            </div>
            <div class="table-responsive">
                <table class="table align-middle">
                    <thead>
                        <tr>
                            <th>Belge turu</th>
                            <th>Dosya / evrak no</th>
                            <th>Tarih</th>
                            <th class="text-end">Islem</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var invoice in Model.Invoices.OrderByDescending(i => i.DocumentDate))
                        {
                            <tr>
                                <td>@invoice.DocumentType</td>
                                <td>
                                    @if (!string.IsNullOrEmpty(invoice.FilePath))
                                    {
                                        <a href="@invoice.FilePath" target="_blank">@invoice.DocumentNumber</a>
                                    }
                                    else
                                    {
                                        @invoice.DocumentNumber
                                    }
                                </td>
                                <td>@invoice.DocumentDate.ToString("dd.MM.yyyy")</td>
                                <td class="text-end">
                                    <form asp-controller="Projects" asp-action="RemoveDocument" asp-route-id="@invoice.Id" method="post" class="d-inline">
                                        <button type="submit" class="btn btn-outline-danger btn-sm border-0" title="Çıkart"><i class="bi bi-trash"></i></button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</section>
