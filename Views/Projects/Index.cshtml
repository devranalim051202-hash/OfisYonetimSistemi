@model IEnumerable<OfisYonetimSistemi.Models.Project>

@{
    ViewData["Title"] = "Projeler";
}

<section class="dashboard-page">
    <div class="dashboard-header">
        <div>
            <p class="eyebrow">Proje Yonetimi</p>
            <h1>Projeler</h1>
            <p>Ofiste takip edilen isleri proje bazli kaydedin ve ilgili stok, gider ve evrak kayitlarini buradan izleyin.</p>
        </div>
        <a class="btn btn-primary" asp-controller="Projects" asp-action="Create">Proje Ekle</a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">@TempData["SuccessMessage"]</div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
    }

    <div class="premium-list-panel">
        <div class="premium-list-header">
            <div>
                <span class="premium-panel-label">Aktif Portfoy</span>
                <h2>Proje portfoyu</h2>
            </div>
            <span class="premium-count">@Model.Count() proje</span>
        </div>

        @if (!Model.Any())
        {
            <div class="premium-empty-state">
                <span>+</span>
                <h3>Henuz proje eklenmedi</h3>
                <p>Ilk projeyi olusturarak gider, evrak ve malzeme takiplerini proje icinde toplamaya baslayin.</p>
                <a class="btn btn-primary" asp-controller="Projects" asp-action="Create">Ilk Projeyi Ekle</a>
            </div>
        }
        else
        {
            <div class="project-card-grid">
                @foreach (var project in Model)
                {
                    var finishDate = project.EndDate?.ToString("dd.MM.yyyy") ?? "Devam ediyor";
                    <article class="project-card">
                        <div class="project-card-glow"></div>
                        <div class="project-card-top">
                            <span class="project-monogram">@project.Name.Substring(0, 1).ToUpper()</span>
                            <span class="status-pill premium-status">@project.Status</span>
                        </div>

                        <div class="project-card-body">
                            <h3>@project.Name</h3>
                            <p>@(string.IsNullOrWhiteSpace(project.Description) ? "Bu proje icin henuz aciklama eklenmedi." : project.Description)</p>
                        </div>

                        <div class="project-meta-grid">
                            <div>
                                <span>Konum</span>
                                <strong>@(project.Location ?? "-")</strong>
                            </div>
                            <div>
                                <span>Baslangic</span>
                                <strong>@project.StartDate.ToString("dd.MM.yyyy")</strong>
                            </div>
                            <div>
                                <span>Bitis</span>
                                <strong>@finishDate</strong>
                            </div>
                        </div>

                        <div class="project-card-actions">
                            <a class="btn btn-primary" asp-controller="Projects" asp-action="Details" asp-route-id="@project.Id">Projeye Gir</a>
                            <a class="btn btn-outline-secondary" asp-controller="Projects" asp-action="Edit" asp-route-id="@project.Id">Duzenle</a>
                            <a class="btn btn-link text-danger" asp-controller="Projects" asp-action="Delete" asp-route-id="@project.Id">Sil</a>
                        </div>
                    </article>
                }
            </div>
        }
    </div>
</section>
