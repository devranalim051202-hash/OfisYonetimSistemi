@model IEnumerable<OfisYonetimSistemi.Models.Project>

@{
    ViewData["Title"] = "Projeler";
}

<section class="dashboard-page">
    <div class="dashboard-header">
        <div>
            <p class="eyebrow"><i class="bi bi-briefcase-fill me-2"></i>Proje Yönetimi</p>
            <h1>Projeler</h1>
            <p>Ofiste takip edilen isleri proje bazli kaydedin ve ilgili stok, gider ve evrak kayitlarini buradan izleyin.</p>
        </div>
        <a class="btn btn-primary shadow-sm" asp-controller="Projects" asp-action="Create"><i class="bi bi-plus-lg me-2"></i>Proje Ekle</a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success shadow-sm"><i class="bi bi-check-circle-fill me-2"></i>@TempData["SuccessMessage"]</div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger shadow-sm"><i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["ErrorMessage"]</div>
    }

    <div class="premium-list-panel mt-4">
        <div class="premium-list-header border-bottom pb-3 mb-4">
            <div>
                <span class="premium-panel-label"><i class="bi bi-card-list me-2"></i>Proje Listesi</span>
                <h2 class="mt-2">Proje Portföyü</h2>
            </div>
            <span class="premium-count bg-light"><i class="bi bi-collection me-2"></i>@Model.Count() proje</span>
        </div>

        @if (!Model.Any())
        {
            <div class="premium-empty-state">
                <span><i class="bi bi-folder-plus"></i></span>
                <h3>Henuz proje eklenmedi</h3>
                <p>Ilk projeyi olusturarak gider, evrak ve malzeme takiplerini proje icinde toplamaya baslayin.</p>
                <a class="btn btn-primary" asp-controller="Projects" asp-action="Create"><i class="bi bi-plus-lg me-2"></i>Ilk Projeyi Ekle</a>
            </div>
        }
        else
        {
            <div class="project-card-grid">
                @foreach (var project in Model)
                {
                    var finishDate = project.EndDate?.ToString("dd.MM.yyyy") ?? "Devam ediyor";
                    var coverImage = project.ProjectImages.FirstOrDefault(i => i.IsCover) ?? project.ProjectImages.FirstOrDefault();
                    var cardStyle = coverImage != null ? $"background-image: url('{coverImage.FilePath}');" : "";
                    <article class="project-card project-card-photo @(coverImage != null ? "has-project-photo" : "no-project-photo")" style="@cardStyle">
                        <div class="project-card-photo-overlay"></div>
                        <div class="project-card-top">
                            <span class="project-monogram shadow-sm">@project.Name.Substring(0, 1).ToUpper()</span>
                            <span class="status-pill premium-status shadow-sm"><i class="bi bi-activity me-2"></i>@project.Status</span>
                        </div>

                        <div class="project-card-body">
                            <h3>@project.Name</h3>
                            <p class="text-muted">@(string.IsNullOrWhiteSpace(project.Description) ? "Bu proje icin henuz aciklama eklenmedi." : project.Description)</p>
                        </div>

                        <div class="project-meta-grid">
                            <div>
                                <span><i class="bi bi-geo-alt me-2 text-primary"></i>Konum</span>
                                <strong>@(project.Location ?? "-")</strong>
                            </div>
                            <div>
                                <span><i class="bi bi-calendar-event me-2 text-success"></i>Başlangıç</span>
                                <strong>@project.StartDate.ToString("dd.MM.yyyy")</strong>
                            </div>
                            <div>
                                <span><i class="bi bi-calendar-check me-2 text-danger"></i>Bitiş</span>
                                <strong>@finishDate</strong>
                            </div>
                        </div>

                        <div class="project-card-actions mt-3">
                            <a class="btn btn-primary flex-grow-1" asp-controller="Projects" asp-action="Details" asp-route-id="@project.Id"><i class="bi bi-arrow-right-circle me-1"></i>Projeye Gir</a>
                            <a class="btn btn-outline-secondary px-3" asp-controller="Projects" asp-action="Edit" asp-route-id="@project.Id" title="Düzenle"><i class="bi bi-pencil-square"></i></a>
                            <a class="btn btn-outline-danger px-3 border-0" asp-controller="Projects" asp-action="Delete" asp-route-id="@project.Id" title="Sil"><i class="bi bi-trash"></i></a>
                        </div>
                    </article>
                }
            </div>
        }
    </div>
</section>
